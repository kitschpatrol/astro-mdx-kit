{
	"extends": "@kitschpatrol/typescript-config",
	"compilerOptions": {
		// Additions and changes from Astro's strictest tsconfig
		// vs. the extended @kitschpatrol/typescript-config
		"target": "ESNext",
		"jsx": "preserve",
		"allowUnusedLabels": false,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true
	},
	// Includes project dot-files files for typescript-eslint integration
	"include": [
		"**/*",
		"**/**.*",
		// Starlight first: generated `astro:content` type aliases collide across
		// playgrounds and the first declaration wins, so the one with the `docs`
		// collection must come before the collection-less plain playgrounds.
		"./playground-satteri-starlight/.astro/types.d.ts",
		"./playground-unified-starlight/.astro/types.d.ts",
		"./playground-satteri/.astro/types.d.ts",
		"./playground-unified/.astro/types.d.ts"
	],
	"exclude": ["**/dist/", "**/bin/"],
	"mdx": {
		"plugins": ["remark-directive", "remark-attribute-list"]
	}
}
