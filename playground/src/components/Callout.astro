---
type Props = {
	title?: string | undefined
	variant?: string | undefined
}

const { title, variant } = Astro.props

const borderColor = variant === 'warning' ? 'orange' : variant === 'tip' ? 'green' : 'blue'
---

<aside style={`border-left: 4px solid ${borderColor}; padding: 0.5em 1em; margin: 1em 0;`}>
	{title && <strong>{title}</strong>}
	<slot />
</aside>
